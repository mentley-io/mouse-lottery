# -----------------------------
# Backend
# -----------------------------
# API server port
PORT=4001

# MongoDB connection
MONGODB_URI=mongodb://localhost:27017/mouse_lottery?authSource=admin

# JWT secrets and expiration
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Super admin bootstrap account
SUPER_ADMIN_PHONE=+254700000001
SUPER_ADMIN_PASSWORD=ChangeMe123!

# If true, backend startup fails when bootstrap checks fail
BOOTSTRAP_STRICT_MODE=false

# -----------------------------
# Frontend
# -----------------------------
# Public API base URL used by frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:4001
