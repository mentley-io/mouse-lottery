# -----------------------------
# Backend
# -----------------------------
# API server port
PORT=4001

# MongoDB connection
MONGODB_URI=mongodb://localhost:27017/mouse_lottery?authSource=admin

# JWT secrets and expiration
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Super admin bootstrap account
SUPER_ADMIN_PHONE=+254700000001
SUPER_ADMIN_PASSWORD=ChangeMe123!

# If true, backend startup fails when bootstrap checks fail
BOOTSTRAP_STRICT_MODE=false

# Comma-separated list of allowed origins for CORS (use * to allow all)
# Example: CORS_ALLOWED_ORIGINS=http://localhost:3000,http://159.65.140.126
# Production: set to your actual domain, e.g. https://mouse-lottery.weedza.co
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000

# -----------------------------
# Merchant Callbacks
# -----------------------------
# Callback URLs for external merchant integrations (server-to-server)
# Leave empty or omit if the merchant is not used in this environment
MERCHANT_KE7STG_CALLBACK_URL=
MERCHANT_KE7PROD_CALLBACK_URL=

# -----------------------------
# Frontend
# -----------------------------
# Public API base URL used by frontend
# Local dev only: set to http://localhost:4001
# Docker/production: leave empty (nginx proxies /api/* to backend)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4001
